# ElixirMind Environment Variables
# Copy this file to .env and customize for your setup

# Bot Operation Mode
ELIXIR_REAL_MODE=false
ELIXIR_DEBUG=true
ELIXIR_SAFE_MODE=true

# Emulator Configuration
ELIXIR_EMULATOR=memu
ELIXIR_DEVICE=127.0.0.1:21503
ADB_PATH=adb

# Strategy Settings
ELIXIR_USE_RL=false
ELIXIR_STRATEGY=heuristic
AGGRESSION_LEVEL=0.6

# Performance Settings
TARGET_FPS=10
LOOP_DELAY=0.1

# Dashboard Configuration
DASHBOARD_PORT=8501
DASHBOARD_HOST=localhost
ENABLE_DASHBOARD=true

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true

# Development
PYTHONPATH=.
